{{ "<?xml version=\"1.0\" encoding=\"UTF-8\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <description>{{ .Site.Params.description }}</description>
    <link>{{ .Site.BaseURL }}</link>
    <atom:link href="{{ "/feed.xml" | absURL }}" rel="self" type="application/rss+xml"/>
    <pubDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <generator>Hugo {{ hugo.Version }}</generator>
    {{ $posts := where .Site.RegularPages "Type" "blog" }}
    {{ range first 10 $posts.ByDate.Reverse }}
      <item>
        <title>{{ .Title }}</title>
        <description>{{ .Content | html }}</description>
        <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
        <link>{{ .Permalink }}</link>
        <guid isPermaLink="true">{{ .Permalink }}</guid>
      </item>
    {{ end }}
  </channel>
</rss>
